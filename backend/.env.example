# ============================================================
# InboxAlert — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=InboxAlert
DEBUG=true
FRONTEND_URL=http://localhost:3000

# ── JWT (RS256) ───────────────────────────────────────────────
# Generate with: ssh-keygen -t rsa -b 2048 -m PEM
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Encryption (AES-256-GCM) ─────────────────────────────────
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_string_here

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://inboxalert:inboxalert_dev_secret@localhost:5432/inboxalert

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:inboxalert_redis_dev@localhost:6379/0

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Microsoft OAuth ───────────────────────────────────────────
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback


# ── WhatsApp Business API (Meta) ─────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# ── AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Webhook Security ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
OUTLOOK_WEBHOOK_CLIENT_STATE=your_random_secret

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
